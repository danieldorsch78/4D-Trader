# Provider API Keys (optional — app runs in demo/mock mode without them)

# Twelve Data (free tier available)
# TWELVE_DATA_API_KEY=your_key_here

# Polygon.io (free tier available)
# POLYGON_API_KEY=your_key_here

# Finnhub (free tier available)
# FINNHUB_API_KEY=your_key_here

# NOTE: The app is fully functional in mock/demo mode.
# API keys are only needed when switching to a live data provider.
# Never commit actual API keys to version control.
